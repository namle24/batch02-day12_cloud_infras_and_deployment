# Copy this file to .env for local development. Never commit .env.

HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

APP_NAME=Day 12 Production AI Agent
APP_VERSION=1.0.0
LLM_MODEL=mock-llm

AGENT_API_KEY=change-me-to-a-long-random-secret
ALLOWED_ORIGINS=*

REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0
HISTORY_TTL_SECONDS=2592000
MAX_HISTORY_MESSAGES=20
